# Token del bot — obténlo en Telegram hablando con @BotFather → /newbot
TELEGRAM_BOT_TOKEN=

# Supabase — igual que en el .env.local del frontend
SUPABASE_URL=https://ypbshbnixkpynmpefqjd.supabase.co
SUPABASE_SERVICE_KEY=

# OCR — Claude Haiku primero (más confiable), Groq como fallback
ANTHROPIC_KEY=
GROQ_KEY=

# Chat IDs de Telegram autorizados (separados por coma).
# Usa /myid en el bot para conocer tu chat ID.
# Estos mismos IDs reciben el resumen diario y las notificaciones de comprobantes.
# Si se deja vacío, cualquier usuario puede acceder pero el resumen diario no se envía.
ALLOWED_CHAT_IDS=
